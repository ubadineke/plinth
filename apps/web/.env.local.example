# Copy to `.env.local` to configure the dashboard.

# ── Mock / design mode ───────────────────────────────────────────────────────
# Serve fixtures (lib/fixtures.ts) instead of calling the backend, so the whole
# dashboard renders fully-populated with NO engine, Postgres, or seeding.
# Ideal for design/UI work. Set to "true" to enable.
NEXT_PUBLIC_USE_MOCKS=true

# ── Live mode (ignored when NEXT_PUBLIC_USE_MOCKS=true) ───────────────────────
# NEXT_PUBLIC_API_URL=http://localhost:7331
#
# ADMIN_SECRET must match the engine's own ADMIN_SECRET. Deliberately NOT prefixed
# NEXT_PUBLIC_ — it's only read server-side, by the /api/admin/* proxy route, and
# must never reach the client bundle.
# ADMIN_SECRET=plinth_admin_2026
